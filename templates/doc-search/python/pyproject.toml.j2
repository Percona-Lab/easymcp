[project]
name = "<< project_slug >>"
version = "0.1.0"
description = "<< description >>"
readme = "README.md"
license = {text = "<< license >>"}
requires-python = ">=3.11"
keywords = ["mcp", "documentation", "semantic-search", "chromadb"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "Topic :: Documentation",
]
dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.34",
    "chromadb>=1.0",
    "fastmcp>=2.0",
    "gitpython>=3.1",
    "python-dotenv>=1.0",
]

[project.scripts]
<< project_slug >>-ingest = "<< package_name >>.ingest:main"
<< project_slug >>-server = "<< package_name >>.server:main"
<< project_slug >>-mcp = "<< package_name >>.mcp_server:main"

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "httpx>=0.27",
    "pytest-asyncio>=0.24",
]

[build-system]
requires = ["setuptools>=75"]
build-backend = "setuptools.build_meta"
