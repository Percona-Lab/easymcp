# << project_name >> Configuration
# Copy to .env and customize

# Comma-separated list of GitHub repos to index (owner/repo format)
REPOS=<% for source in all_sources %><< source.slug >><% if not loop.last %>,<% endif %><% endfor %>

# Check for doc updates every N days (0 to disable)
REFRESH_DAYS=<< refresh_days >>

# Data directory (default: data/ in project root)
# DATA_DIR=data
