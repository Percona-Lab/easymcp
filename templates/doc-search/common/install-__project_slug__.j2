#!/bin/bash
# << project_name >> Installer
# Usage: curl -fsSL https://raw.githubusercontent.com/<< github_repo_url | replace('https://github.com/', '') >>/main/install-<< project_slug >> | bash

set -euo pipefail

# NOTE: Do NOT use `exec bash <(curl ...) </dev/tty` to fix interactive prompts.
# That pattern is unreliable across shells and terminal types. Instead, this
# bootstrap stays non-interactive and delegates all prompts to the Python
# installer where input() handles terminal I/O correctly.

INSTALLER_URL="https://raw.githubusercontent.com/<< github_repo_url | replace('https://github.com/', '') >>/main/installer.py"

echo ""
echo "<< project_name >> Installer"
echo ""

# ── Install uv if needed ───────────────────────────────────────
if ! command -v uv &>/dev/null; then
  echo "  Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
  if ! command -v uv &>/dev/null; then
    echo "  uv installed but not in PATH. Restart your shell and re-run."
    exit 1
  fi
  echo "  uv installed."
fi

# ── Download and run the Python installer ─────────────────────
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

echo "  Downloading installer..."
curl -fsSL "$INSTALLER_URL" -o "$TMPDIR/installer.py"

echo ""
uv run --python 3.12 "$TMPDIR/installer.py" < /dev/tty
