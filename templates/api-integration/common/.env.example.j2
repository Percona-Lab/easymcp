# << project_name >> Configuration
# Copy to .env and customize

<% if auth_method == "bearer" %>
# API key for << service_name >>
<< service_slug | upper >>_API_KEY=your-api-key-here
<% elif auth_method == "basic" %>
# Credentials for << service_name >>
<< service_slug | upper >>_USERNAME=your-username
<< service_slug | upper >>_PASSWORD=your-password
<% elif auth_method == "oauth2" %>
# OAuth 2.0 credentials for << service_name >>
<< service_slug | upper >>_CLIENT_ID=your-client-id
<< service_slug | upper >>_CLIENT_SECRET=your-client-secret
<< service_slug | upper >>_TOKEN_URL=<< base_url >>/oauth/token
<% else %>
# Credentials for << service_name >> (customize as needed)
<< service_slug | upper >>_API_KEY=your-api-key-here
<% endif %>

# Base URL for << service_name >> API
<< service_slug | upper >>_BASE_URL=<< base_url >>
